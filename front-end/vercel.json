{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://dognet.runasp.net/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
        {
      "source": "/api/views",
      "destination": "/api/views.js"
    },
    {
      "source": "/(.*)",
      "destination": "/front-end/$1"
    }
  ]
}